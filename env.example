# SAM.gov API Credentials
# Get your API key from your SAM.gov Workspace -> Account Details
SAM_API_KEY=YOUR_SAM_API_KEY_HERE

# USAspending.gov API Credentials (Optional)
# Public API key or token if proxying/rate limiting requires it
USASPENDING_API_KEY=

# API Endpoint URLs (Keyless or Key-supported)
SAM_API_URL=https://api.sam.gov/opportunities/v2/search
USASPENDING_API_URL=https://api.usaspending.gov/api/v2

